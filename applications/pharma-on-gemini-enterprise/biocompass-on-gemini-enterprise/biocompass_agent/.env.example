GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=YOUR_PROJECT_ID
GOOGLE_CLOUD_LOCATION=us-central1

# Gemini 3.x is only served from the `global` endpoint; Agent Engine itself
# still deploys regionally (GOOGLE_CLOUD_LOCATION above).
MODEL_LOCATION=global

# Coordinator + planner / synth / critic model.
COORDINATOR_MODEL_NAME=gemini-3.1-pro-preview

# Faster model for sub-agents and parallel retrievers.
WORKER_MODEL_NAME=gemini-3-flash-preview

# Image model for visualize_concept (Nano Banana Pro). Supports 1K, 2K, 4K.
IMAGE_MODEL_NAME=gemini-3-pro-image-preview
IMAGE_SIZE=2K

# Critic loop bound for the deep-research pipeline.
MAX_CRITIC_ROUNDS=2

# Optional: an NCBI API key raises the E-utilities rate limit from 3 -> 10 req/sec.
# Get one at https://www.ncbi.nlm.nih.gov/account/settings/
# PUBMED_API_KEY=
