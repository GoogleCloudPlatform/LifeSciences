GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=YOUR_PROJECT_ID
GOOGLE_CLOUD_LOCATION=us-central1

# Gemini 3.x is only served from the `global` endpoint; Agent Engine itself
# still deploys regionally (GOOGLE_CLOUD_LOCATION above).
MODEL_LOCATION=global

# Planner / Stylist / Critic model (multimodal text + vision in)
PLANNER_MODEL_NAME=gemini-3.1-pro-preview

# Visualizer model (image generation; multimodal in for refinement edits)
IMAGE_MODEL_NAME=gemini-3-pro-image-preview

# Output image size: 1K, 2K, or 4K (Nano Banana Pro). 4K = publication quality
# but slower per round; drop to 2K or 1K for faster iteration.
IMAGE_SIZE=4K

# Maximum critic refinement rounds (visualizer + critic per round).
MAX_CRITIC_ROUNDS=3
