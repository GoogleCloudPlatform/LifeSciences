# ============================================================================
# Vertex AI Configuration (DEFAULT)
# ============================================================================
# Use Vertex AI for production deployments with BigQuery integration
GOOGLE_GENAI_USE_VERTEXAI=True
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ============================================================================
# AI Studio Configuration (ALTERNATIVE)
# ============================================================================
# To use AI Studio API instead of Vertex AI:
# 1. Set GOOGLE_GENAI_USE_VERTEXAI=False
# 2. Get an API key from https://aistudio.google.com/apikey
# 3. Set GOOGLE_API_KEY=your-api-key
# Note: BigQuery features require Vertex AI and won't work with AI Studio
# GOOGLE_GENAI_USE_VERTEXAI=False
# GOOGLE_API_KEY=your-api-key-here

# ============================================================================
# Model Configuration (optional)
# ============================================================================
# Use Flash for simple tasks (orchestration, search, retrieval, SQL)
ROOT_MODEL=gemini-2.5-flash
WORKER_MODEL=gemini-2.5-flash
BIGQUERY_MODEL=gemini-2.5-flash

# Use Pro ONLY for heavy synthesis and critical evaluation
CRITIC_MODEL=gemini-2.5-pro
SYNTHESIS_MODEL=gemini-2.5-pro

# ============================================================================
# Research Configuration
# ============================================================================
MAX_SEARCH_ITERATIONS=2

# ============================================================================
# Agent Engine Deployment Configuration (deploy-ae.sh)
# ============================================================================
# ADK deployment settings for deploying the agent to Vertex AI Agent Engine
# Create a GCS bucket for staging deployment artifacts:
#   gsutil mb -p your-project-id -l us-central1 gs://your-project-staging-bucket
ADK_STAGING_BUCKET=gs://your-project-staging-bucket
ADK_REGION=us-central1
ADK_DISPLAY_NAME=Research Agent
ADK_DESCRIPTION=Multi-source research agent with PubMed, Patents, Clinical Trials, and Web Research

# ============================================================================
# AgentSpace Deployment Configuration (deploy-ge.sh)
# ============================================================================
# Google AgentSpace (Gen App Builder) deployment settings
# Prerequisites:
#   1. Deploy to Agent Engine first using deploy-ae.sh
#   2. Create an AgentSpace app in Gen App Builder console
#   3. Get the Agent Engine ID from the deployment output

# Project number (numeric, not the project ID)
# Find it: gcloud projects describe YOUR_PROJECT_ID --format="value(projectNumber)"
GOOGLE_CLOUD_PROJECT_NUMBER=your-project-number

# Agent Engine resource ID (from deploy-ae.sh output)
# This is the numeric ID at the end of the reasoning engine resource name
AGENT_ENGINE_ID=your-agent-engine-id
AGENT_ENGINE_LOCATION=us-central1

# AgentSpace app configuration
# Find the app ID in Gen App Builder > Apps
AGENTSPACE_APP_ID=your-agentspace-app-id
AGENTSPACE_LOCATION=global

# Optional: Override display name/description for AgentSpace
# (defaults to ADK_DISPLAY_NAME and ADK_DESCRIPTION if not set)
# AGENTSPACE_DISPLAY_NAME=Research Agent
# AGENTSPACE_DESCRIPTION=Multi-source research agent with PubMed, Patents, Clinical Trials, and Web Research
