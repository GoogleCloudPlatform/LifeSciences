# ==============================================================================
# deploy-all.sh — Optional configuration overrides
# ==============================================================================
# Copy this file to .env in the same directory and fill in any values you need
# to override. All settings are optional — FoldRun derives sensible defaults
# from PROJECT_ID for standard deployments.
#
#   cp .env.example .env
#   # Edit .env, then run:
#   ./deploy-all.sh YOUR_PROJECT_ID us-central1 --steps build
#
# Priority order (highest wins):
#   1. Environment variables set before invoking the script
#   2. This .env file
#   3. FoldRun naming-convention defaults (PROJECT_ID-based)
# ==============================================================================

# ==============================================================================
# Resource naming overrides (OPTIONAL)
# Only needed if your Terraform provisioned non-default names.
# FoldRun defaults are shown as comments — leave unset to use them.
# ==============================================================================

# GCS bucket for pipeline data and results (default: {PROJECT_ID}-foldrun-data)
# GCS_BUCKET=my-project-foldrun-data

# GCS bucket for genetic databases (default: {PROJECT_ID}-foldrun-gdbs)
# DATABASES_BUCKET=my-project-foldrun-gdbs

# Artifact Registry repo name (default: foldrun-repo)
# AR_REPO=foldrun-repo

# Filestore instance ID (default: foldrun-nfs)
# FILESTORE_ID=foldrun-nfs

# Service account emails (defaults derived from PROJECT_ID)
# AGENT_SA_EMAIL=foldrun-agent-sa@my-project.iam.gserviceaccount.com
# BUILD_SA_EMAIL=foldrun-build-sa@my-project.iam.gserviceaccount.com
# PIPELINES_SA_EMAIL=pipelines-sa@my-project.iam.gserviceaccount.com

# ==============================================================================
# Shared VPC (REQUIRED if bringing your own network)
# Set these if FoldRun is deployed into a Shared VPC owned by a host project.
# See README Step 2c for full Shared VPC setup instructions.
# ==============================================================================

# Full resource path of the VPC network in the host project:
#   projects/{HOST_PROJECT_ID}/global/networks/{NETWORK_NAME}
# NETWORK_ID=projects/my-host-project/global/networks/my-shared-vpc

# Full resource path of the subnet in the host project:
#   projects/{HOST_PROJECT_ID}/regions/{REGION}/subnetworks/{SUBNET_NAME}
# SUBNET_ID=projects/my-host-project/regions/us-central1/subnetworks/my-subnet

# Numeric project number of the host project (not the ID):
#   gcloud projects describe HOST_PROJECT_ID --format='value(projectNumber)'
# NETWORK_PROJECT_NUMBER=123456789012

# ==============================================================================
# Container image versions (OPTIONAL)
# Only needed to pin to a specific build rather than :latest
# ==============================================================================
# AF2_VERSION=42719e135a62438aa651d2bc1d143626083c3703
# OF3_VERSION=0.3.1
# BOLTZ_VERSION=2.2.1

# ==============================================================================
# Other overrides (OPTIONAL)
# ==============================================================================
# Database download mode: reduced (default, skips large BFD) or full
# DOWNLOAD_MODE=reduced

# IAP domain for the viewer (defaults to your gcloud account domain)
# IAP_ACCESS_DOMAIN=your-org.com
