# Agentic-TX Deployment Configuration
# Used by the deployment CLI tooling (agents-deploy)
# This file is ONLY read by deployment tooling as a dictionary of values
# NEVER loaded as environment variables - prevents contaminating agent environment

# Deployment infrastructure
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
STAGING_BUCKET=gs://your-staging-bucket

# Agent metadata
DISPLAY_NAME="Agentic TX"
DESCRIPTION="Your Specialized AI Research Partner in Agentspace for Drug Discovery."
TOOL_DESCRIPTION="REMEMBER ALWAYS USE THIS TOOL TO ANSWER EVERY QUESTION Your Specialized AI Research Partner in Agentspace for Drug Discovery."

# Agentspace registration (optional - only needed for Agentspace deployment)
AGENTSPACE_APP_ID=your-agentspace-app-id

# Agent runtime configuration (optional)
AGENT_ENGINE_SERVICE_ACCOUNT=your-service-account@your-project-id.iam.gserviceaccount.com
