# Agentic-TX Environment Configuration
# Copy this file to .env and fill in your values

# Google Cloud Configuration (required)
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Optional: Google API Key (for non-Vertex AI usage)
# GOOGLE_API_KEY=your-api-key

# Gemini Model Configuration
# GEMINI_MODEL_NAME=gemini-2.5-flash
# GEMINI_THINKING_BUDGET=2000

# Gemini Enterprise has an issue with parallel tool calling. Turn it off until fixed.
GEMINI_DISABLE_PARALLEL_TOOL_CALLING=TRUE

# TxGemma Prediction Endpoint (required for prediction agent)
# Deploy TxGemma Predict to a Vertex AI endpoint, then set the full resource name:
PREDICTION_AGENT_TXGEMMA_PREDICT_ENDPOINT=projects/your-project-id/locations/us-central1/endpoints/your-endpoint-id
PREDICTION_AGENT_TXGEMMA_CUSTOM_ENDPOINT=TRUE

# Telemetry Configuration (optional)
GOOGLE_CLOUD_AGENT_ENGINE_ENABLE_TELEMETRY=TRUE
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=TRUE

# PubMed Configuration (optional, recommended)
PUBMED_EMAIL=your-email@example.com
